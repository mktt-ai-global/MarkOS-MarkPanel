# --- Required Settings ---
# Database configuration
DATABASE_URL=postgresql+asyncpg://markos:markos_pass@markos-db:5432/markos_db
REDIS_URL=redis://markos-redis:6379/0

# Security - Generate a random 32-character string
SECRET_KEY=replace_me_with_random_32_chars

# Domain for SSL and CORS (e.g., markos.local or 192.168.1.100)
DOMAIN=localhost
PANEL_PORT=80

# --- Admin Credentials (Only for first install) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Storage Settings ---
# Absolute path to the cloud storage root on host
STORAGE_ROOT=/data/storage
MAX_UPLOAD_SIZE_GB=50

# --- Module Configuration ---
# Multi-user mode (true/false)
MULTI_USER_MODE=false

# Terminal configuration
ENABLE_TERMINAL=true
TERMINAL_MAX_SESSIONS=4

# Weather API (Optional)
WEATHER_API_KEY=
WEATHER_CITY=Shanghai

# --- Frontend Settings ---
# API URL (internal/external)
NEXT_PUBLIC_API_URL=http://localhost/api

# --- Logging & Infrastructure ---
LOG_LEVEL=INFO
POSTGRES_USER=markos
POSTGRES_PASSWORD=markos_pass
POSTGRES_DB=markos_db
